# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL with connection pooling)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/api_gateway?connection_limit=10&pool_timeout=20"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Upstream API (dummy API for proxying)
UPSTREAM_URL=https://jsonplaceholder.typicode.com

# Rate Limiting
DEFAULT_RATE_LIMIT=10
DEFAULT_RATE_PERIOD=60000
